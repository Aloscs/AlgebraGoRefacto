<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorFondoPersonalizado">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/score_container"
        android:layout_width="@dimen/main_score_container_width"
        android:layout_height="@dimen/main_score_container_height"
        android:layout_marginTop="@dimen/main_top_margin"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="@dimen/main_score_shadow_width"
            android:layout_height="@dimen/score_tag_height"
            android:layout_gravity="center"
            android:background="@drawable/bg_neobrutal_tag_shadow"
            android:translationX="@dimen/shadow_offset_xsmall"
            android:translationY="@dimen/shadow_offset_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tv_score_main"
            android:layout_width="@dimen/main_score_button_width"
            android:layout_height="@dimen/score_tag_height"
            android:layout_gravity="center"
            android:backgroundTint="@color/score_yellow"
            android:clickable="true"
            android:focusable="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="@dimen/margin_medium"
            android:paddingEnd="@dimen/margin_medium"
            android:text="@string/main_score_default"
            android:textColor="?attr/colorTextoPersonalizado"
            android:textSize="@dimen/text_score"
            android:textStyle="bold"
            app:cornerRadius="@dimen/pill_radius"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="@dimen/neo_stroke_width" />

    </FrameLayout>

    <View
        android:layout_width="@dimen/main_icon_size"
        android:layout_height="@dimen/main_icon_size"
        android:layout_marginStart="@dimen/margin_large"
        android:layout_marginTop="@dimen/main_icon_top_margin"
        android:background="@drawable/bg_shadow_icon"
        android:translationX="@dimen/shadow_offset_small"
        android:translationY="@dimen/shadow_offset_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="@dimen/main_icon_size"
        android:layout_height="@dimen/main_icon_size"
        android:layout_marginStart="@dimen/margin_large"
        android:layout_marginTop="@dimen/main_icon_top_margin"
        android:background="@drawable/bg_neobrutal_icon"
        android:padding="@dimen/hint_icon_padding"
        android:src="@drawable/ic_settings"
        android:contentDescription="@string/settings_title"
        app:tint="@color/neo_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="@dimen/main_icon_size"
        android:layout_height="@dimen/main_icon_size"
        android:layout_marginEnd="@dimen/margin_large"
        android:layout_marginTop="@dimen/main_icon_top_margin"
        android:background="@drawable/bg_shadow_icon"
        android:translationX="@dimen/shadow_offset_small"
        android:translationY="@dimen/shadow_offset_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btn_achievements_icon"
        android:layout_width="@dimen/main_icon_size"
        android:layout_height="@dimen/main_icon_size"
        android:layout_marginEnd="@dimen/margin_large"
        android:layout_marginTop="@dimen/main_icon_top_margin"
        android:background="@drawable/bg_neobrutal_icon"
        android:padding="@dimen/hint_icon_padding"
        android:src="@drawable/ic_trophy"
        android:contentDescription="@string/achievements_title"
        app:tint="@color/neo_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="?attr/colorTextoPersonalizado"
        android:textSize="@dimen/text_feedback_title"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/main_title_margin_top"
        app:layout_constraintTop_toBottomOf="@id/btn_settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_subtitle"
        android:textColor="@color/gray_medium"
        android:textSize="@dimen/text_body_medium"
        android:layout_marginTop="@dimen/margin_small"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/logoContainer"
        android:layout_width="@dimen/main_logo_size"
        android:layout_height="@dimen/main_logo_size"
        android:layout_marginTop="@dimen/blocks_title_margin_top"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_logo"
            android:layout_width="@dimen/main_logo_size"
            android:layout_height="@dimen/main_logo_size"
            android:background="@color/neo_white"
            android:padding="@dimen/hint_icon_padding"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.AlgebraGo.Circle"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="@dimen/neo_stroke_width" />

    </FrameLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="@dimen/main_button_margin_horizontal"
        android:layout_marginEnd="@dimen/main_button_margin_horizontal"
        android:layout_marginTop="@dimen/main_start_button_margin_top"
        android:background="@drawable/bg_shadow_button"
        android:translationX="@dimen/shadow_offset_small"
        android:translationY="@dimen/shadow_offset_small"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start"
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="@dimen/main_button_margin_horizontal"
        android:layout_marginEnd="@dimen/main_button_margin_horizontal"
        android:layout_marginTop="@dimen/main_start_button_margin_top"
        android:text="@string/btn_start"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="@dimen/text_button_large"
        android:textColor="?attr/colorTextoPersonalizado"
        android:backgroundTint="@color/card_blue"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:strokeWidth="@dimen/neo_stroke_width"
        app:strokeColor="@color/neo_black"
        app:cornerRadius="@dimen/main_button_radius"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="@dimen/main_button_margin_horizontal"
        android:layout_marginEnd="@dimen/main_button_margin_horizontal"
        android:layout_marginTop="@dimen/main_progress_button_margin_top"
        android:background="@drawable/bg_shadow_button"
        android:translationX="@dimen/shadow_offset_small"
        android:translationY="@dimen/shadow_offset_small"
        app:layout_constraintTop_toBottomOf="@id/btn_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_progress"
        android:layout_width="0dp"
        android:layout_height="@dimen/main_button_height"
        android:layout_marginStart="@dimen/main_button_margin_horizontal"
        android:layout_marginEnd="@dimen/main_button_margin_horizontal"
        android:layout_marginTop="@dimen/main_progress_button_margin_top"
        android:text="@string/btn_progress"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="@dimen/text_button_large"
        android:textColor="?attr/colorTextoPersonalizado"
        android:backgroundTint="@color/feedback_finish_purple"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:strokeWidth="@dimen/neo_stroke_width"
        app:strokeColor="@color/neo_black"
        app:cornerRadius="@dimen/main_button_radius"
        app:layout_constraintTop_toBottomOf="@id/btn_start"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_footer_hint"
        android:textColor="@color/gray_medium"
        android:textSize="@dimen/text_score"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/blocks_title_margin_top"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?attr/colorFondoPersonalizado"
        app:itemTextColor="?attr/colorTextoPersonalizado"
        app:menu="@menu/drawable_menu" />

</androidx.drawerlayout.widget.DrawerLayout>