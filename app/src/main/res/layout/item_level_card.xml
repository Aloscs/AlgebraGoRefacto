<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container_level"
    android:layout_width="match_parent"
    android:layout_height="@dimen/level_item_height"
    android:padding="@dimen/margin_explanation_small"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_level_circle"
        android:layout_width="@dimen/level_circle_size"
        android:layout_height="@dimen/level_circle_size"
        android:text=""
        android:textColor="?attr/colorTextoPersonalizado"
        android:textSize="@dimen/text_result"
        android:textStyle="bold"
        android:backgroundTint="@color/feedback_finish_purple"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="@dimen/level_circle_radius"
        app:strokeWidth="@dimen/neo_stroke_width"
        app:strokeColor="@color/neo_black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_level"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_explanation_small"
        app:cardCornerRadius="@dimen/main_button_radius"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/neo_white"
        app:layout_constraintStart_toEndOf="@id/btn_level_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_level_circle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/level_card_inner_padding"
            android:clipChildren="false"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/tv_level_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/level_name_default"
                android:textColor="@color/neo_black"
                android:textStyle="bold"
                android:textSize="@dimen/text_toolbar" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/shadow_margin"
                android:paddingEnd="@dimen/margin_small"
                android:paddingBottom="@dimen/margin_small"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/level_desc_shadow_default"
                    android:textColor="?attr/colorTextoPersonalizado"
                    android:textSize="@dimen/text_score"
                    android:paddingStart="@dimen/margin_score_edge"
                    android:paddingTop="@dimen/level_tag_padding_vertical"
                    android:paddingEnd="@dimen/margin_score_edge"
                    android:paddingBottom="@dimen/level_tag_padding_vertical"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:translationX="@dimen/shadow_margin_small"
                    android:translationY="@dimen/shadow_margin_small"
                    android:background="@drawable/bg_level_desc_shadow" />

                <TextView
                    android:id="@+id/tv_level_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/level_desc_default"
                    android:textColor="@color/block_description_gray"
                    android:textSize="@dimen/text_score"
                    android:minLines="2"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:paddingStart="@dimen/margin_score_edge"
                    android:paddingTop="@dimen/level_tag_padding_vertical"
                    android:paddingEnd="@dimen/margin_score_edge"
                    android:paddingBottom="@dimen/level_tag_padding_vertical"
                    android:background="@drawable/bg_level_desc_outline" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_level_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/level_status_new"
                android:textColor="?attr/colorTextoPersonalizado"
                android:textSize="@dimen/text_xsmall"
                android:layout_marginTop="0dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>