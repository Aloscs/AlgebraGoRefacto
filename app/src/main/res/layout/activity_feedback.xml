<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorFondoPersonalizado">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/margin_small">

        <FrameLayout
            android:id="@+id/back_feedback_container"
            android:layout_width="@dimen/neo_icon_container_size"
            android:layout_height="@dimen/neo_icon_container_size"
            android:layout_marginStart="@dimen/margin_score_edge"
            android:layout_marginTop="@dimen/margin_score_edge"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <View
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:layout_gravity="center"
                android:background="@drawable/bg_shadow_icon"
                android:translationX="@dimen/shadow_offset_small"
                android:translationY="@dimen/shadow_offset_small" />

            <ImageButton
                android:id="@+id/btn_back_feedback"
                android:layout_width="@dimen/icon_size_large"
                android:layout_height="@dimen/icon_size_large"
                android:layout_gravity="center"
                android:background="@drawable/bg_neobrutal_icon"
                android:src="@drawable/ic_arrow_back"
                android:padding="@dimen/icon_padding_medium"
                android:contentDescription="@string/btn_back"
                app:tint="@color/neo_black" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/score_feedback_container"
            android:layout_width="@dimen/score_container_width"
            android:layout_height="@dimen/score_container_height"
            android:layout_marginTop="@dimen/margin_score_edge"
            android:layout_marginEnd="@dimen/margin_score_edge"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="@dimen/score_tag_width"
                android:layout_height="@dimen/score_tag_height"
                android:layout_gravity="center"
                android:background="@drawable/bg_neobrutal_tag_shadow"
                android:translationX="@dimen/shadow_offset_small"
                android:translationY="@dimen/shadow_offset_small" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tv_score_feedback"
                android:layout_width="@dimen/score_tag_width"
                android:layout_height="@dimen/score_tag_height"
                android:layout_gravity="center"
                android:text="@string/score_default"
                android:textColor="?attr/colorTextoPersonalizado"
                android:textSize="@dimen/text_score"
                android:textStyle="bold"
                android:clickable="false"
                android:focusable="false"
                android:backgroundTint="@color/score_yellow"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="@dimen/score_padding_horizontal"
                android:paddingEnd="@dimen/score_padding_horizontal"
                app:cornerRadius="@dimen/pill_radius"
                app:strokeColor="@color/neo_black"
                app:strokeWidth="@dimen/neo_stroke_width" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_feedback_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feedback_results_title"
            android:textColor="?attr/colorTextoPersonalizado"
            android:textSize="@dimen/text_feedback_title"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/explanation_steps_padding"
            app:layout_constraintTop_toBottomOf="@id/back_feedback_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_feedback_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feedback_subtitle"
            android:textColor="@color/gray_medium"
            android:textSize="@dimen/text_small"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/blocks_subtitle_margin_top"
            app:layout_constraintTop_toBottomOf="@id/tv_feedback_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_feedback_tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/feedback_exercise_count"
            android:textColor="@color/neo_black"
            android:textSize="@dimen/text_score"
            android:textStyle="bold"
            android:paddingStart="@dimen/margin_medium"
            android:paddingEnd="@dimen/margin_medium"
            android:paddingTop="@dimen/margin_small"
            android:paddingBottom="@dimen/margin_small"
            android:rotation="@integer/tag_rotation"
            android:background="@drawable/bg_neobrutal_tag"
            android:layout_marginTop="@dimen/text_small"
            app:layout_constraintTop_toBottomOf="@id/tv_feedback_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="@dimen/margin_explanation_small"
        android:paddingEnd="@dimen/margin_explanation_small">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_shadow_block"
            android:translationX="@dimen/shadow_offset_medium"
            android:translationY="@dimen/shadow_offset_medium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/neo_white"
            app:cardCornerRadius="@dimen/equation_card_radius"
            app:cardElevation="0dp"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="@dimen/neo_stroke_width">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/ll_feedback_cards"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_medium" />

            </ScrollView>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/margin_medium">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry_level"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/btn_retry"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="?attr/colorTextoPersonalizado"
            android:backgroundTint="@color/feedback_retry_yellow"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="@dimen/neo_stroke_width"
            app:cornerRadius="@dimen/explanation_button_radius"
            android:layout_marginEnd="@dimen/margin_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_finish_feedback"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:text="@string/btn_view_score"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="?attr/colorTextoPersonalizado"
            android:backgroundTint="@color/feedback_finish_purple"
            app:strokeColor="@color/neo_black"
            app:strokeWidth="@dimen/neo_stroke_width"
            app:cornerRadius="@dimen/explanation_button_radius" />

    </LinearLayout>

</LinearLayout>
