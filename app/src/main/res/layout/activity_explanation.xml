<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F1E8">

    <LinearLayout
        android:id="@+id/header_explanation"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="60dp"
        android:background="#B8D8FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_explanation_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explicación"
            android:textColor="#111111"
            android:textSize="32sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_explanation_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repasemos los conceptos"
            android:textColor="#4E4E4E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/back_explanation_container"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_shadow_icon"
            android:translationX="4dp"
            android:translationY="4dp"/>
        <ImageButton
            android:id="@+id/btn_back_explanation"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_neobrutal_icon"
            android:src="@drawable/ic_arrow_back"
            android:padding="12dp"
            android:contentDescription="Regresar"
            app:tint="#111111"/>
    </FrameLayout>

    <!-- Contenedor score con sombra -->
    <FrameLayout
        android:id="@+id/wrap_content"
        android:layout_width="wrap_content"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="135dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_neobrutal_tag_shadow"
            android:translationX="4dp"
            android:translationY="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tv_score_explanation"
            android:layout_width="135dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:text="Puntos: 0"
            android:textColor="#111111"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="false"
            android:focusable="false"
            android:backgroundTint="#FAC705"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            app:cornerRadius="50dp"
            app:strokeColor="#111111"
            app:strokeWidth="3dp"/>

    </FrameLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/header_explanation"
        app:layout_constraintBottom_toTopOf="@id/footer_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="147dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_neobrutal_icon"
                    android:gravity="center"
                    android:text="🤖"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/tv_explanation_body"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_block_card"
                    android:lineSpacingExtra="4dp"
                    android:padding="16dp"
                    android:text="¡Hola! Para resolver estas ecuaciones, el secreto es mantener el equilibrio en ambos lados del signo igual."
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:maxLines="6"
                    android:scrollbars="vertical" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Procedimiento:"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginBottom="12dp"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@color/black"
                    android:translationX="6dp"
                    android:translationY="6dp"
                    app:layout_constraintTop_toTopOf="@id/tv_explanation_steps"
                    app:layout_constraintBottom_toBottomOf="@id/tv_explanation_steps"
                    app:layout_constraintStart_toStartOf="@id/tv_explanation_steps"
                    app:layout_constraintEnd_toEndOf="@id/tv_explanation_steps"/>

                <TextView
                    android:id="@+id/tv_explanation_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_block_card"
                    android:padding="20dp"
                    android:text="1. Identifica la incógnita\n2. Agrupa términos semejantes\n3. Despeja la variable"
                    android:textColor="#4E4E4E"
                    android:fontFamily="monospace"
                    android:textSize="14sp"
                    android:lineSpacingExtra="8dp"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footer_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_shadow_button"
            android:translationX="4dp"
            android:translationY="4dp"
            app:layout_constraintTop_toTopOf="@id/btn_start_exercise"
            app:layout_constraintBottom_toBottomOf="@id/btn_start_exercise"
            app:layout_constraintStart_toStartOf="@id/btn_start_exercise"
            app:layout_constraintEnd_toEndOf="@id/btn_start_exercise"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_exercise"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="¡EMPEZAR EJERCICIO!"
            android:textColor="#111111"
            android:textStyle="bold"
            android:backgroundTint="#66C557"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeWidth="3dp"
            app:strokeColor="#111111"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>