<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.androide.algebrago">

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.AlgebraGo">

        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.BlockSelectionActivity" />
        <activity android:name=".activities.LevelSelectionActivity" />
        <activity android:name=".activities.ExplanationActivity" />
        <activity android:name=".activities.ExerciseActivity" />
        <activity android:name=".activities.FeedbackActivity" />
        <activity android:name=".activities.ProgressActivity" />
        <activity android:name=".activities.AchievementsActivity" />
        <activity android:name=".activities.ScoreActivity" />

    </application>

</manifest>
